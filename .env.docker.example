# ============================================================
# Docker 编排参数（与应用配置 .env 严格分离）
# 复制为 .env.docker 后编辑；compose 会自动读取仓库根的 .env
# 用法：cp .env.docker.example .env.docker
#       docker compose --env-file .env.docker up -d
# ============================================================

# ----- 镜像版本 -----
# 建议与 VERSION 文件保持一致
AFTERGLOW_VERSION=0.2.5

# ----- 端口 -----
# 宿主机暴露端口；容器内固定 8000
AFTERGLOW_HOST_PORT=8000

# ----- 容器名 -----
# 多实例部署时改这里
BACKEND_CONTAINER_NAME=afterglow-backend

# ----- 数据目录（关键）-----
# 容器挂载的宿主机工作目录，里面会有 .env 和 .data/。
# 默认就是仓库内 ./backend，开发场景与源码部署共享配置和数据。
# 如果你想把数据放到仓库外（例如生产部署），填绝对路径：
#   AFTERGLOW_DATA_DIR=/var/lib/afterglow
#   AFTERGLOW_DATA_DIR=/home/user/afterglow-data
# 该目录如果不存在或为空，容器首次启动会自动初始化并触发配置向导。
AFTERGLOW_DATA_DIR=./backend
