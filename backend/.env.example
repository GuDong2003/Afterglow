# ============================================================
# Afterglow（续温）—— 示例配置
# 复制为 .env 并填写需要的值。请勿将 .env 提交到 git。
# .env 已在仓库 .gitignore 中。
# ============================================================

# ============================================================
# 【基础设置】首次运行必填
# ============================================================

# ----- 你和朋友的身份信息 -----
# 打开 QQChatExporter 导出的 JSON，找到顶部的 chatInfo 字段：
#   - selfUid 填到 SELF_UID
#   - selfName 填到 SELF_NAME（或你喜欢的名字）
# 然后在 messages 数组里找一条 sender.uid 不等于 selfUid 的消息，
#   - 它的 uid 填到 FRIEND_UID
#   - sender.name 或 sender.remark 填到 FRIEND_NAME
SELF_NAME=
SELF_UID=
FRIEND_NAME=
FRIEND_UID=

# ----- 别名（可选）-----
# 朋友间互相称呼时经常会混用真名/网名/昵称/外号。把所有别名列在这里，
# cleaner / retriever / prompt 都会识别这些是同一个人。
# 用逗号分隔；不需要带引号。例如：
#   SELF_ALIASES=小明,Mike,明哥
#   FRIEND_ALIASES=阿巴,小巴,巴神
# 不设置 = 没有别名，系统只认 SELF_NAME / FRIEND_NAME。
SELF_ALIASES=
FRIEND_ALIASES=

# ----- 你们的关系（用于 prompt 选择合适的语气）-----
# friend：朋友（默认）/ lover：恋人 / family：亲人 / colleague：同事 / custom：自定义
RELATIONSHIP_TYPE=friend
# 仅当 RELATIONSHIP_TYPE=custom 时**必填**，填写自由描述（如"高中同桌""一起长大的发小"）
RELATIONSHIP_DESCRIPTION=

# ----- LLM（OpenAI 兼容接口）-----
# 用于对话生成。你可以用 OpenAI 官方、DeepSeek、Moonshot、Qwen、本地 ollama 等任何兼容接口。
# 填【基础地址】，不要包含 /chat/completions（程序会自动拼接，写了也会被识别）。
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
CHAT_MODEL=gpt-4o

# ----- 生活时间线小模型（可选，留空则复用上面的 LLM 配置）-----
# 它只负责维护 AI 自己的日常状态 JSON，不负责最终回复。
# 可用便宜快的小模型，例如 glm-4-flash / qwen-turbo / 其它 OpenAI 兼容模型。
LIFE_API_URL=
LIFE_API_KEY=
LIFE_MODEL=
LIFE_TEMPERATURE=0.35
LIFE_MAX_TOKENS=320
# 最长多久让 life 小模型重新判断一次当前状态。0 = 只按 next_update_at / 用户打断触发。
LIFE_UPDATE_INTERVAL_MINUTES=60
# 状态模型可建议”晚一点回复”；这里限制实际延迟上限，避免请求卡太久。
LIFE_MAX_REPLY_DELAY_SECONDS=45
# 主模型可在回复末尾输出 <life-update>{...}</life-update> 标记块，
# 后端解析后**直接** patch life（不调小模型，零额外 API 成本），并从对外回复中剥离。
# true：解析 + 应用 + 剥离；false：仅剥离（兜底，避免前端看到内部协议）。
LIFE_MARKER_UPDATE_ENABLED=true

# ----- 本轮互动决策小模型（可选，默认关闭）-----
# 规则引擎会先给出本轮"撒娇/接梗/转移/认真/沉默/要图/要表情"等基础决策；
# 开启此项后，会再调用一次小模型对意图做有界微调：
#   - 不能降低 risk_level（low→medium→high 只能上调）
#   - 不能让 should_reply=false 变成 true
#   - 不能撤销规则层标记的"要图/要表情/沉默/安全风险"判断
# 留空 RESPONSE_POLICY_* 时复用 LIFE_*；LIFE_* 也未配则复用主 LLM。
RESPONSE_POLICY_MODEL_ENABLED=false
RESPONSE_POLICY_API_URL=
RESPONSE_POLICY_API_KEY=
RESPONSE_POLICY_MODEL=
RESPONSE_POLICY_TEMPERATURE=0.2
RESPONSE_POLICY_MAX_TOKENS=260

# ----- 沉默响应（AI 主动选择不回复时的对外格式）-----
# 决策层判断本轮不应回复时，后端会跳过主模型调用并返回一个空回复。
# content 字段会放一个 sentinel，让标准 OpenAI 客户端通过 content==sentinel
# 或 policy.should_reply==false 识别沉默场景。
SILENCE_RESPONSE_SENTINEL=[silent]
# finish_reason 默认用扩展值 silenced（语义最清晰）；
# 严格 enum 校验的 OpenAI SDK 可改成 stop 走标准协议。
SILENCE_FINISH_REASON=silenced

# ----- /v1/responses 服务端缓存 -----
# OpenAI Responses API 通过 previous_response_id 找回上一轮上下文。
# Afterglow 用进程内 LRU 缓存 response_id → conversation_id 的映射，
# 重启即丢失，不持久化。
RESPONSES_STORE_CAPACITY=512

# ----- 向量模型（Qwen3-Embedding-8B，通过 OpenAI 兼容的 /embeddings 调用）-----
# 用于把聊天文本转成向量入库。
# 填【基础地址】，不要包含 /embeddings（程序会自动拼接，写了也会被识别）。
# 常见示例：
#   阿里云 DashScope：https://dashscope.aliyuncs.com/compatible-mode/v1
#   Gitee AI：       https://ai.gitee.com/v1
#   OpenAI：         https://api.openai.com/v1
#   本地 ollama：    http://127.0.0.1:11434/v1
EMBEDDING_API_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
EMBEDDING_API_KEY=
EMBEDDING_MODEL=Qwen3-Embedding-8B
EMBEDDING_DIM=4096
# 请求格式：
#   array  = OpenAI 标准（input 是 string 数组，一次多条；默认，DashScope/OpenAI/ollama 都支持）
#   single = 单条模式（input 是单个 string，一次一条；Gitee AI 等只接受这种）
EMBEDDING_INPUT_MODE=array
# 每次请求的最大文本数。single 模式下强制为 1。array 模式下若上游限制更小可调小。
EMBEDDING_BATCH_SIZE=25
# 最大并发请求数。只限制同时在飞的 HTTP 请求，不等价于每分钟限速。
EMBEDDING_MAX_CONCURRENCY=4
# 每分钟最多发起多少个 embedding HTTP 请求。0 表示不主动限速。
EMBEDDING_MAX_REQUESTS_PER_MINUTE=0
# 是否在请求体中带 encoding_format="float"。OpenAI 原生支持，但部分网关会因 schema
# 校验失败而拒绝。如果出现 400 "No schema matches"，把它设为 false。
EMBEDDING_INCLUDE_ENCODING_FORMAT=true
# 是否在请求体中带 dimensions=EMBEDDING_DIM 字段。支持 MRL 的服务（OpenAI
# text-embedding-3 / DashScope text-embedding-v3 / Qwen3-Embedding 兼容网关）
# 必须开启，否则上游可能用默认维度（常被降到 1024），导致 Afterglow 维度校验失败。
# 极少数老网关不识别该字段会 400；遇到那种情况关掉它并把 EMBEDDING_DIM 调到上游默认。
EMBEDDING_SEND_DIMENSIONS=true

# ============================================================
# 【常用可选】根据需要修改
# ============================================================

# ----- 应用元数据（前端展示用）-----
APP_NAME=Afterglow
APP_SLOGAN=把曾经对你好的话，续成往后的陪伴
# 传给模型的真实当前时区。用于“今天 / 现在 / 睡没睡 / 吃没吃”等时间相关回复。
APP_TIMEZONE=Asia/Shanghai

# ----- 隐私 -----
# PII 脱敏开关，默认开启
# 内置规则脱敏：手机号、邮箱、身份证、银行卡、IP。
# 注意：QQ 号、URL、域名按设计**保留**，模型需要 uid 关联且 URL 是对话语境的一部分。
ENABLE_PII_REDACTION=true
# 可选：自定义脱敏规则文件路径（YAML/JSON，格式见 docs）
PII_RULES_PATH=

# ----- 视觉理解（vision / VLM）-----
# 总开关。默认关闭，避免新用户配置出错。
VISION_ENABLED=false
# 主对话模型是否原生支持视觉（OpenAI multimodal 格式）。
# - true：图片直接转发到主 LLM（要求主模型是 GPT-4o / Qwen-VL / Gemini 等 VLM）
# - false：先调下面的 VISION_MODEL 把图片转成文字描述，再以纯文本发给主模型
CHAT_MODEL_SUPPORTS_VISION=false
# 当主模型不支持视觉时使用的 VLM（OpenAI 兼容）
# 留空且 CHAT_MODEL_SUPPORTS_VISION=false 时，发图会返回 400。
VISION_API_URL=
VISION_API_KEY=
VISION_MODEL=qwen-vl-plus
VISION_DESCRIBE_PROMPT=请用一两句话客观描述这张图片的内容，不要发挥。
# 单张图片最大字节（base64 解码后），默认 8MB
VISION_MAX_IMAGE_BYTES=8388608

# ----- 联网检索（可选，默认关闭）-----
# 默认 provider 是 Tavily（有月度免费额度）。开启后，后端会在用户明确要求
# “搜索/查一下/最新/新闻/天气/价格”等公开信息时，把搜索摘要注入主模型 prompt。
# 注意：这会把本轮查询文本发送给搜索服务；不开启时完全不联网。
WEB_ACCESS_ENABLED=false
# tavily：默认，填 WEB_SEARCH_API_KEY 即可
# searxng：自建/可信 SearXNG，需把 WEB_SEARCH_BASE_URL 改成实例地址
WEB_SEARCH_PROVIDER=tavily
WEB_SEARCH_BASE_URL=https://api.tavily.com
WEB_SEARCH_API_KEY=
WEB_SEARCH_MAX_RESULTS=5
WEB_SEARCH_TIMEOUT_SECONDS=8
WEB_SEARCH_LANGUAGE=zh-CN
# 用户消息包含完整 URL 时，后端可读取网页标题和正文摘录并注入 prompt。
# 用户只写裸域名时，会先用本地规则判断访问意图，命中后再调用 LIFE_* 小模型确认。
# 仍受 WEB_ACCESS_ENABLED 总开关控制；会请求用户发来的公开 URL / 小模型确认后的裸域名。
WEB_FETCH_ENABLED=true
WEB_FETCH_TIMEOUT_SECONDS=8
WEB_FETCH_MAX_URLS=2
WEB_FETCH_MAX_REDIRECTS=3
WEB_FETCH_MAX_BYTES=524288
WEB_FETCH_MAX_CHARS=6000

# ----- 数据存储位置（本地路径）-----
LANCE_DB_PATH=.data/lancedb
PERSONA_DATA_DIR=.data/persona
# 图片按 SHA-256 文件名持久化的目录
IMAGE_DATA_DIR=.data/images

# ----- 本地 chat API 守卫（启动 chat_api 后生效）-----
# 默认强制鉴权：除 /healthz 外，所有后端路由都需要 Bearer 或 x-api-key。
# 对外部署务必填写长随机值；纯本地临时开发可设 API_AUTH_REQUIRED=false。
#
# 注意：只要配置了 XUWEN_API_KEY（非空），即使 API_AUTH_REQUIRED=false 也仍会校验 token。
# 这是为了防止"我以为关了鉴权但 KEY 还在所以不用带"的混淆。
# 配置矩阵：
#   API_AUTH_REQUIRED=false + XUWEN_API_KEY=空    → 完全开放，任何请求直接通过
#   API_AUTH_REQUIRED=false + XUWEN_API_KEY=有值  → 仍强制带 Bearer <key>
#   API_AUTH_REQUIRED=true  + XUWEN_API_KEY=空    → 503 错误（要求鉴权但 KEY 没配）
#   API_AUTH_REQUIRED=true  + XUWEN_API_KEY=有值  → 正确：请求必须带 Bearer <key>
API_AUTH_REQUIRED=true
XUWEN_API_KEY=

# ----- 版本更新检查 -----
# 默认开启：后端启动时一次性调用 UPDATE_CHECK_URL（GitHub Releases API），
# 把最新版本信息暴露给 /info 接口供前端展示。
# 后续要再查由前端"立即检查"按钮触发，后端不再周期性主动拉。
# 只请求公开 URL，不传任何身份 / 配置 / API key；离线 / CI 场景可关。
UPDATE_CHECK_ENABLED=true
UPDATE_CHECK_URL=https://api.github.com/repos/kldhsh123/Afterglow/releases/latest
UPDATE_CHECK_TIMEOUT_SECONDS=8

# ============================================================
# 【进阶调优】不熟悉可保留默认值
# ============================================================

# ----- 人格模板 -----
# 内置：xuwen（续温·朋友陪伴）/ friend / lover / family / colleague
# 或填写自定义 *.md.j2 的绝对路径
PERSONA_TEMPLATE=xuwen
# 可选：完全覆盖内置模板目录
PROMPT_TEMPLATE_DIR=

# ----- 切分参数 -----
SESSION_GAP_MINUTES=30
WINDOW_SIZE=12
WINDOW_OVERLAP=3
SINGLE_CONTEXT_BEFORE=6
SINGLE_CONTEXT_AFTER=2

# ----- 检索调优参数 -----
RESPONSE_PAIR_TOP_K=24
FRIEND_TOP_K=32
WINDOW_TOP_K=16
LIVE_TOP_K=12
FINAL_CONTEXT_K=12
RRF_K=60
RECENCY_HALF_LIFE_DAYS=30
RECENCY_MAX_BOOST=0.15
WARMTH_BOOST=0.12
LIVE_SOURCE_WEIGHT=1.08
HISTORY_SOURCE_WEIGHT=1.0
AI_GENERATED_SOURCE_WEIGHT=0.25
# 是否允许 ai_generated 跨会话长期累积并参与 live 语义检索。
# false：只在同一 conversation_id 内用于连续性；true：允许长期变化被检索到。
AI_GENERATED_LONG_TERM_ENABLED=false
WRITEBACK_ENABLED=true
WRITEBACK_QUEUE_SIZE=1000
# 每个会话累积多少轮才批量向量化 + 入库（默认 8 轮，即 16 条消息）。
# 小一点：记忆更新更快；大一点：节省 embedding API 调用数。
WRITEBACK_BATCH_TURNS=8
# 兜底定时器：会话超过这个秒数没新消息，pending 会被强制 flush。
WRITEBACK_FLUSH_INTERVAL_SECONDS=300
# 是否对回写文本做向量化。
# - true：批量入库时调 embedding API（每 batch_turns 一次请求）
# - false：所有 live_messages 用零向量入库（最省 API，但 live 不参与向量召回）
WRITEBACK_VECTORIZE=true

# LanceDB 写库单批 merge_insert 行数。导入大库时如果出现 "Spill has sent an error"，
# 优先降到 64 或 32；值越小越稳，但写库更慢。
LANCE_UPSERT_BATCH_SIZE=128

# ----- 语义标签（小模型给 chunk 打 mood / topic / importance）-----
# 总开关。默认关闭。开启后所有 chunk 都会过一遍小模型打软标签，用于精召回 / 主动筛选。
# 标签只作为加权信号，未命中也能被向量召回。
LABELING_ENABLED=false
# 默认指向智谱 GLM-4-Flash（免费额度）；可改任意 OpenAI 兼容 endpoint
LABEL_API_URL=https://open.bigmodel.cn/api/paas/v4
LABEL_API_KEY=
LABEL_MODEL=glm-4-flash
# 单次 LLM 调用最多塞几条消息
LABEL_BATCH_SIZE=8
# 同时允许多少个打标批次请求在飞。1 = 上一批处理完再下一批。
# 例如 GLM-4-Flash 账号并发上限 20，可先设 15，给重试和其它请求留余量。
LABEL_MAX_CONCURRENCY=1
# 请求发起间隔（秒）。默认 0 不额外等待；如果仍遇到 429，可设 0.2 / 0.5 / 1。
LABEL_REQUEST_INTERVAL_SECONDS=0
# 累积多少条 chunk 触发一次打标周期（Phase B 异步队列才用，本期一次性同步跑）
LABEL_FLUSH_AFTER_N=20
LABEL_FLUSH_INTERVAL_SECONDS=300
# 离线增量：只标"还没打过"的 chunk（永远开）
LABEL_INCREMENTAL=true
LABEL_MAX_CHARS_PER_MESSAGE=200
# 自定义 mood 枚举，逗号分隔；留空使用内置 8 个（安慰/调侃/分享/请求/吐槽/认真讨论/日常/撒娇）
LABEL_MOOD_VOCAB=
